{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "react",
    "react-perf",
    "import",
    "promise",
    "typescript",
    "vitest"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "warn",
    "perf": "warn"
  },
  "ignorePatterns": [
    "dist/",
    "**/*.{spec,bench}.tsx",
    "**/*.{cjs,js}"
  ],
  "rules": {
    "eqeqeq": ["error", "smart"]
  }
}
