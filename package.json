{
    "name": "hyper-react",
    "type": "module",
    "private": true,
    "packageManager": "yarn@4.13.0",
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18"
    },
    "scripts": {
        "build": "tsc && vite build",
        "reformat": "prettier --write --cache --log-level warn './**/*.{ts,tsx}'",
        "lint": "yarn run reformat && oxlint",
        "test": "vitest"
    },
    "devDependencies": {
        "@testing-library/dom": "*",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "*",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "happy-dom": "^20.9.0",
        "oxlint": "^1.67.0",
        "prettier": "^3.8.3",
        "tsc": "^2.0.4",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.7"
    },
    "optionalDependencies": {
        "use-between": "1.4.0"
    }
}
